//go:build e2e

package e2e

import (
	"context"
	"database/sql"
	"fmt"
	"testing"
	"time"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestBatchInsert(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	t.Run("MySQL", func(t *testing.T) {
		db := NewMySQLConnection(t, &config.MySQL)
		testBatchInsert(t, db, "mysql")
	})

	t.Run("PostgreSQL", func(t *testing.T) {
		db := NewPostgreSQLConnection(t, &config.PostgreSQL)
		testBatchInsert(t, db, "postgres")
	})
}

func testBatchInsert(t *testing.T, db *sql.DB, dbType string) {
	ctx := context.Background()
	users := GenerateTestUsers(100)

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err, "Should begin transaction")
	defer tx.Rollback()

	start := time.Now()
	for _, user := range users {
		var query string
		if dbType == "mysql" {
			query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)"
		} else {
			query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb)"
		}

		_, err := tx.ExecContext(ctx, query,
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
		require.NoError(t, err, "Batch insert should succeed")
	}
	duration := time.Since(start)

	err = tx.Commit()
	require.NoError(t, err, "Transaction commit should succeed")

	t.Logf("Inserted 100 users in %v", duration)

	for _, user := range users {
		CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
	}
}

func TestBatchUpdate(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx := context.Background()

	rows, err := db.QueryContext(ctx, "SELECT id FROM users LIMIT 50")
	require.NoError(t, err, "Should query user IDs")
	defer rows.Close()

	var userIDs []int64
	for rows.Next() {
		var id int64
		err := rows.Scan(&id)
		require.NoError(t, err)
		userIDs = append(userIDs, id)
	}

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err, "Should begin transaction")
	defer tx.Rollback()

	start := time.Now()
	for _, id := range userIDs {
		_, err := tx.ExecContext(ctx, "UPDATE users SET balance = balance + 10 WHERE id = ?", id)
		require.NoError(t, err, "Batch update should succeed")
	}
	duration := time.Since(start)

	err = tx.Commit()
	require.NoError(t, err, "Transaction commit should succeed")

	t.Logf("Updated %d users in %v", len(userIDs), duration)
}

func TestBatchDelete(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx := context.Background()
	users := GenerateTestUsers(30)

	for _, user := range users {
		_, err := db.ExecContext(ctx,
			"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
		require.NoError(t, err, "Setup insert should succeed")
	}

	start := time.Now()
	for _, user := range users {
		_, err := db.ExecContext(ctx, "DELETE FROM users WHERE username = ?", user.Username)
		require.NoError(t, err, "Batch delete should succeed")
	}
	duration := time.Since(start)

	t.Logf("Deleted %d users in %v", len(users), duration)
}

func TestMixedBatchOperations(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx := context.Background()
	users := GenerateTestUsers(20)

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err)
	defer tx.Rollback()

	start := time.Now()

	for i, user := range users {
		_, err := tx.ExecContext(ctx,
			"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
		require.NoError(t, err, "INSERT should succeed")

		if i%3 == 0 {
			_, err := tx.ExecContext(ctx, "UPDATE users SET balance = ? WHERE username = ?", user.Balance+100, user.Username)
			require.NoError(t, err, "UPDATE should succeed")
		}

		if i%5 == 0 {
			_, err := tx.ExecContext(ctx, "DELETE FROM users WHERE username = ?", user.Username)
			require.NoError(t, err, "DELETE should succeed")
		}
	}

	duration := time.Since(start)
	err = tx.Commit()
	require.NoError(t, err)

	t.Logf("Mixed batch operations completed in %v", duration)

	for i, user := range users {
		if i%5 != 0 {
			CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
		}
	}
}

func TestBatchPerformance(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx := context.Background()
	users := GenerateTestUsers(100)

	t.Run("IndividualInserts", func(t *testing.T) {
		start := time.Now()
		for _, user := range users {
			_, err := db.ExecContext(ctx,
				"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
				user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
			require.NoError(t, err)
		}
		individualDuration := time.Since(start)

		for _, user := range users {
			CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
		}

		t.Logf("Individual inserts: %v", individualDuration)
	})

	t.Run("TransactionBatchInserts", func(t *testing.T) {
		tx, err := db.BeginTx(ctx, nil)
		require.NoError(t, err)
		defer tx.Rollback()

		start := time.Now()
		for _, user := range users {
			_, err := tx.ExecContext(ctx,
				"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
				user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
			require.NoError(t, err)
		}
		batchDuration := time.Since(start)

		err = tx.Commit()
		require.NoError(t, err)

		for _, user := range users {
			CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
		}

		t.Logf("Transaction batch inserts: %v", batchDuration)
	})
}

func TestBatchSizeLimit(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx := context.Background()
	users := GenerateTestUsers(1001)

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err)

	_, err = tx.ExecContext(ctx, "SET SESSION max_prepared_stmt_count = 1000")
	if err != nil {
		t.Skip("Could not set prepared statement limit")
	}

	for i, user := range users {
		if i >= 1000 {
			break
		}
		_, err := tx.ExecContext(ctx,
			"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
		if err != nil {
			t.Logf("Batch limit reached at %d inserts", i)
			break
		}
	}

	tx.Rollback()
}

func TestBatchErrorHandling(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx := context.Background()

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err)

	users := GenerateTestUsers(5)
	for i, user := range users {
		if i == 2 {
			_, err := tx.ExecContext(ctx,
				"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
				"alice", "alice@example.com", "hash", "Test", 30, 100, true)
			assert.Error(t, err, "Duplicate key should return error")
		} else {
			_, err := tx.ExecContext(ctx,
				"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
				user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
			if err != nil {
				t.Logf("Insert %d failed: %v", i, err)
			}
		}
	}

	tx.Rollback()
}

func BenchmarkBatchInsert(b *testing.B) {
	config, err := LoadConfig()
	if err != nil {
		b.Skip("Failed to load config")
	}

	db, err := sql.Open("mysql", config.MySQL.DSN())
	if err != nil {
		b.Skip("Failed to connect to MySQL")
	}
	defer db.Close()

	ctx := context.Background()

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		user := GenerateTestUser()
		_, err := db.ExecContext(ctx,
			"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
		if err != nil {
			b.Errorf("Insert failed: %v", err)
		}

		db.ExecContext(ctx, "DELETE FROM users WHERE username = ?", user.Username)
	}
}
