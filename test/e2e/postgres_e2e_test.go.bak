//go:build e2e

package e2e

import (
	"context"
	"database/sql"
	"fmt"
	"sync"
	"testing"
	"time"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestPostgreSQLConnection(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewPostgreSQLConnection(t, &config.PostgreSQL)

	t.Run("SuccessfulConnection", func(t *testing.T) {
		ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()

		err := db.PingContext(ctx)
		assert.NoError(t, err, "Should successfully ping PostgreSQL database")
	})

	t.Run("HealthCheck", func(t *testing.T) {
		ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()

		var result int
		err := db.QueryRowContext(ctx, "SELECT 1").Scan(&result)
		assert.NoError(t, err, "Health check query should succeed")
		assert.Equal(t, 1, result, "Health check should return 1")
	})
}

func TestPostgreSQLConnectionPool(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewPostgreSQLConnection(t, &config.PostgreSQL)

	t.Run("ConcurrentConnections", func(t *testing.T) {
		var wg sync.WaitGroup
		errors := make(chan error, 20)

		for i := 0; i < 20; i++ {
			wg.Add(1)
			go func(id int) {
				defer wg.Done()
				ctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
				defer cancel()

				var result int
				err := db.QueryRowContext(ctx, "SELECT 1").Scan(&result)
				if err != nil {
					errors <- fmt.Errorf("goroutine %d: %w", id, err)
				}
			}(i)
		}

		wg.Wait()
		close(errors)

		for err := range errors {
			t.Errorf("Concurrent query error: %v", err)
		}
	})
}

func TestPostgreSQLQueryExecution(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewPostgreSQLConnection(t, &config.PostgreSQL)

	t.Run("SelectQuery", func(t *testing.T) {
		ctx := context.Background()

		rows, err := db.QueryContext(ctx, "SELECT id, username, email FROM users LIMIT 5")
		require.NoError(t, err, "SELECT query should succeed")
		defer rows.Close()

		count := 0
		for rows.Next() {
			var id int
			var username, email string
			err := rows.Scan(&id, &username, &email)
			require.NoError(t, err, "Should scan row successfully")
			count++
		}
		assert.GreaterOrEqual(t, count, 1, "Should return at least 1 user")
	})

	t.Run("InsertQuery", func(t *testing.T) {
		ctx := context.Background()
		user := GenerateTestUser()

		var id int
		err := db.QueryRowContext(ctx,
			`INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) 
			 VALUES ($1, $2, $3, $4, $5, $6, $7, '{"role": "user"}'::jsonb) 
			 RETURNING id`,
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive).
			Scan(&id)
		require.NoError(t, err, "INSERT should succeed")
		assert.Greater(t, id, 0, "Should return valid ID")

		CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
	})

	t.Run("UpdateQuery", func(t *testing.T) {
		ctx := context.Background()
		user := GenerateTestUser()

		var id int
		err := db.QueryRowContext(ctx,
			`INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) 
			 VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb) 
			 RETURNING id`,
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive).
			Scan(&id)
		require.NoError(t, err)

		result, err := db.ExecContext(ctx, "UPDATE users SET balance = balance + 100 WHERE id = $1", id)
		require.NoError(t, err, "UPDATE query should succeed")

		rowsAffected, _ := result.RowsAffected()
		assert.Equal(t, int64(1), rowsAffected, "Should affect 1 row")

		CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
	})
}

func TestPostgreSQLSpecialFeatures(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewPostgreSQLConnection(t, &config.PostgreSQL)

	t.Run("ReturningClause", func(t *testing.T) {
		ctx := context.Background()
		user := GenerateTestUser()

		var id int
		var returnedBalance float64
		err := db.QueryRowContext(ctx,
			`INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) 
			 VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb) 
			 RETURNING id, balance`,
			user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive).
			Scan(&id, &returnedBalance)
		require.NoError(t, err, "INSERT with RETURNING should succeed")
		assert.Equal(t, user.Balance, returnedBalance, "Should return inserted balance")

		CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
	})

	t.Run("JSONBType", func(t *testing.T) {
		ctx := context.Background()

		var metadata []byte
		err := db.QueryRowContext(ctx,
			"SELECT metadata FROM users WHERE id = 1").
			Scan(&metadata)
		require.NoError(t, err, "Should query JSONB field")
		assert.NotEmpty(t, metadata, "JSONB field should not be empty")
	})

	t.Run("ArrayTypes", func(t *testing.T) {
		ctx := context.Background()

		var tags []string
		err := db.QueryRowContext(ctx,
			"SELECT tags FROM products WHERE id = 1").
			Scan(pq.Array(&tags))
		if err == nil {
			assert.NotEmpty(t, tags, "Tags array should not be empty")
		}
	})

	t.Run("CTE", func(t *testing.T) {
		ctx := context.Background()

		rows, err := db.QueryContext(ctx,
			`WITH active_users AS (
				SELECT id, username FROM users WHERE is_active = TRUE
			)
			SELECT COUNT(*) FROM active_users`)
		require.NoError(t, err, "CTE query should succeed")
		defer rows.Close()

		if rows.Next() {
			var count int
			err := rows.Scan(&count)
			require.NoError(t, err)
			assert.GreaterOrEqual(t, count, 0, "Should have active users count")
		}
	})
}

func TestPostgreSQLTimeout(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewPostgreSQLConnection(t, &config.PostgreSQL)

	t.Run("QueryTimeout", func(t *testing.T) {
		ctx, cancel := context.WithTimeout(context.Background(), 1*time.Nanosecond)
		defer cancel()

		time.Sleep(10 * time.Millisecond)

		var result int
		err := db.QueryRowContext(ctx, "SELECT 1").Scan(&result)
		assert.Error(t, err, "Query should timeout")
	})
}

func TestPostgreSQLErrorHandling(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewPostgreSQLConnection(t, &config.PostgreSQL)

	t.Run("UniqueConstraintViolation", func(t *testing.T) {
		ctx := context.Background()

		_, err := db.ExecContext(ctx,
			`INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) 
			 VALUES ('alice', 'alice@example.com', 'hash', 'Test', 30, 100, TRUE, '{}'::jsonb)`)
		assert.Error(t, err, "Duplicate username should return error")
	})

	t.Run("ForeignKeyViolation", func(t *testing.T) {
		ctx := context.Background()

		_, err := db.ExecContext(ctx,
			`INSERT INTO orders (user_id, order_number, total_amount, status) 
			 VALUES (99999, 'ORD-TEST-999', 100, 'pending')`)
		assert.Error(t, err, "Invalid foreign key should return error")
	})
}
