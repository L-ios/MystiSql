//go:build e2e

package e2e

import (
	"context"
	"database/sql"
	"sync"
	"testing"
	"time"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestTransactionCommit(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	t.Run("MySQL", func(t *testing.T) {
		db := NewMySQLConnection(t, &config.MySQL)
		testTransactionCommit(t, db, "mysql")
	})

	t.Run("PostgreSQL", func(t *testing.T) {
		db := NewPostgreSQLConnection(t, &config.PostgreSQL)
		testTransactionCommit(t, db, "postgres")
	})
}

func testTransactionCommit(t *testing.T, db *sql.DB, dbType string) {
	ctx := context.Background()
	user := GenerateTestUser()

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err, "Should begin transaction")

	defer tx.Rollback()

	var query string
	if dbType == "mysql" {
		query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)"
	} else {
		query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb)"
	}

	result, err := tx.ExecContext(ctx, query,
		user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
	require.NoError(t, err, "INSERT in transaction should succeed")

	rowsAffected, _ := result.RowsAffected()
	assert.Equal(t, int64(1), rowsAffected, "Should insert 1 row")

	err = tx.Commit()
	require.NoError(t, err, "Transaction commit should succeed")

	CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
}

func TestTransactionRollback(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	t.Run("MySQL", func(t *testing.T) {
		db := NewMySQLConnection(t, &config.MySQL)
		testTransactionRollback(t, db, "mysql")
	})

	t.Run("PostgreSQL", func(t *testing.T) {
		db := NewPostgreSQLConnection(t, &config.PostgreSQL)
		testTransactionRollback(t, db, "postgres")
	})
}

func testTransactionRollback(t *testing.T, db *sql.DB, dbType string) {
	ctx := context.Background()
	user := GenerateTestUser()

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err, "Should begin transaction")

	var query string
	if dbType == "mysql" {
		query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)"
	} else {
		query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb)"
	}

	_, err = tx.ExecContext(ctx, query,
		user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
	require.NoError(t, err, "INSERT in transaction should succeed")

	err = tx.Rollback()
	require.NoError(t, err, "Transaction rollback should succeed")

	var count int
	err = db.QueryRowContext(ctx, "SELECT COUNT(*) FROM users WHERE username = ?", user.Username).Scan(&count)
	require.NoError(t, err, "Should query count after rollback")
	assert.Equal(t, 0, count, "Data should not persist after rollback")
}

func TestTransactionIsolation(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	t.Run("MySQL", func(t *testing.T) {
		db := NewMySQLConnection(t, &config.MySQL)
		testTransactionIsolation(t, db, "mysql")
	})
}

func testTransactionIsolation(t *testing.T, db *sql.DB, dbType string) {
	ctx := context.Background()
	user := GenerateTestUser()

	tx1, err := db.BeginTx(ctx, &sql.TxOptions{Isolation: sql.LevelReadCommitted})
	require.NoError(t, err, "Should begin transaction 1")

	var query string
	if dbType == "mysql" {
		query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)"
	} else {
		query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb)"
	}

	_, err = tx1.ExecContext(ctx, query,
		user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
	require.NoError(t, err, "INSERT in tx1 should succeed")

	var count int
	err = db.QueryRowContext(ctx, "SELECT COUNT(*) FROM users WHERE username = ?", user.Username).Scan(&count)
	require.NoError(t, err)
	assert.Equal(t, 0, count, "Uncommitted data should not be visible in READ COMMITTED")

	err = tx1.Commit()
	require.NoError(t, err)

	err = db.QueryRowContext(ctx, "SELECT COUNT(*) FROM users WHERE username = ?", user.Username).Scan(&count)
	require.NoError(t, err)
	assert.Equal(t, 1, count, "Committed data should be visible")

	CleanupTable(t, db, "users WHERE username = '"+user.Username+"'")
}

func TestConcurrentTransactions(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	t.Run("MySQL", func(t *testing.T) {
		db := NewMySQLConnection(t, &config.MySQL)
		testConcurrentTransactions(t, db, "mysql")
	})

	t.Run("PostgreSQL", func(t *testing.T) {
		db := NewPostgreSQLConnection(t, &config.PostgreSQL)
		testConcurrentTransactions(t, db, "postgres")
	})
}

func testConcurrentTransactions(t *testing.T, db *sql.DB, dbType string) {
	var wg sync.WaitGroup
	errors := make(chan error, 10)

	for i := 0; i < 10; i++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()

			ctx := context.Background()
			tx, err := db.BeginTx(ctx, nil)
			if err != nil {
				errors <- err
				return
			}

			defer tx.Rollback()

			user := GenerateTestUser()

			var query string
			if dbType == "mysql" {
				query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)"
			} else {
				query = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb)"
			}

			_, err = tx.ExecContext(ctx, query,
				user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
			if err != nil {
				errors <- err
				return
			}

			if err := tx.Commit(); err != nil {
				errors <- err
				return
			}

			CleanupTable(nil, db, "users WHERE username = '"+user.Username+"'")
		}(i)
	}

	wg.Wait()
	close(errors)

	for err := range errors {
		t.Errorf("Concurrent transaction error: %v", err)
	}
}

func TestTransactionMixedOperations(t *testingtesting.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	t.Run("MySQL", func(t *testing.T) {
		db := NewMySQLConnection(t, &config.MySQL)
		testTransactionMixedOperations(t, db, "mysql")
	})
}

func testTransactionMixedOperations(t *testing.T, db *sql.DB, dbType string) {
	ctx := context.Background()
	user := GenerateTestUser()

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err)

	defer tx.Rollback()

	var insertQuery string
	if dbType == "mysql" {
		insertQuery = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)"
	} else {
		insertQuery = "INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active, metadata) VALUES ($1, $2, $3, $4, $5, $6, $7, '{}'::jsonb)"
	}

	result, err := tx.ExecContext(ctx, insertQuery,
		user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)
	require.NoError(t, err)

	userID, _ := result.LastInsertId()

	var count int
	err = tx.QueryRowContext(ctx, "SELECT COUNT(*) FROM users WHERE id = ?", userID).Scan(&count)
	require.NoError(t, err)
	assert.Equal(t, 1, count)

	_, err = tx.ExecContext(ctx, "UPDATE users SET balance = balance + 100 WHERE id = ?", userID)
	require.NoError(t, err)

	_, err = tx.ExecContext(ctx, "DELETE FROM users WHERE id = ?", userID)
	require.NoError(t, err)

	err = tx.Commit()
	require.NoError(t, err)

	err = db.QueryRowContext(ctx, "SELECT COUNT(*) FROM users WHERE id = ?", userID).Scan(&count)
	require.NoError(t, err)
	assert.Equal(t, 0, count, "User should be deleted after commit")
}

func TestTransactionTimeout(t *testing.T) {
	SkipIfShort(t)

	config, err := LoadConfig()
	require.NoError(t, err, "Failed to load config")

	db := NewMySQLConnection(t, &config.MySQL)

	ctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)
	defer cancel()

	tx, err := db.BeginTx(ctx, nil)
	require.NoError(t, err)

	time.Sleep(200 * time.Millisecond)

	user := GenerateTestUser()
	_, err = tx.ExecContext(ctx,
		"INSERT INTO users (username, email, password_hash, full_name, age, balance, is_active) VALUES (?, ?, ?, ?, ?, ?, ?)",
		user.Username, user.Email, user.PasswordHash, user.FullName, user.Age, user.Balance, user.IsActive)

	assert.Error(t, err, "Transaction operation should timeout")
	tx.Rollback()
}
